{
    // 密钥脱敏后缀
    "REDACTED_SUFFIX": "[REDACTED]",
    // 敏感信息正则模式列表，为空时跳过检测，用户可以自由定义需要保护的敏感信息模式
    // 每项包含 description（人类可读描述）和 pattern（字符串或字符串数组）
    "sensitive_patterns": [
        {
            "description": "OpenAI-compatible API Key",
            "pattern": [
                "sk-[A-Za-z0-9_-]+",
                "sk-api-[A-Za-z0-9_-]+"
            ]
        },
        {
            "description": "AWS Access Key ID",
            "pattern": [
                "AKIA[A-Z0-9]{16}"
            ]
        },
        {
            "description": "GitHub Personal Access Token",
            "pattern": [
                "ghp_[A-Za-z0-9_]{36}"
            ]
        },
        {
            "description": "GitHub OAuth Token",
            "pattern": [
                "gho_[A-Za-z0-9_]{36}"
            ]
        },
        {
            "description": "GitLab Personal Access Token",
            "pattern": [
                "glpat-[A-Za-z0-9_-]{20}"
            ]
        },
        {
            "description": "Slack Token (bot, app, user, refresh, service)",
            "pattern": [
                "xox[baprs]-[A-Za-z0-9-]+"
            ]
        },
        {
            "description": "Slack Webhook URL",
            "pattern": [
                "hooks\\.slack\\.com/services/T[A-Z0-9]{8,}/B[A-Z0-9]{8,}/[A-Za-z0-9]+"
            ]
        },
        {
            "description": "JWT Token",
            "pattern": [
                "eyJ[A-Za-z0-9_-]*\\.eyJ[A-Za-z0-9_-]*\\.[A-Za-z0-9_-]*"
            ]
        },
        {
            "description": "PEM Private Key",
            "pattern": [
                "-----BEGIN (?:RSA |EC |DSA )?PRIVATE KEY-----"
            ]
        }
    ]
}
