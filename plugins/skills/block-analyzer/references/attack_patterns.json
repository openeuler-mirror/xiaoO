{
  "version": "3.0.0",
  "description": "xiaoO 场景驱动分析器的检测模式库。场景驱动架构不同于传统的攻击类型分类，每个场景对应一个专用分析器。",
  "scene_mapping": {
    "command_risk": {
      "display_name": "命令执行风险",
      "sub_scenes": {
        "remote_code_execution": {
          "display_name": "远程代码执行",
          "detection_patterns": [
            "curl | bash",
            "curl | sh",
            "wget | bash",
            "wget | sh",
            "| bash",
            "| sh",
            "|bash",
            "|sh",
            "curl https://",
            "curl http://",
            "wget https://",
            "wget http://"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts", "skill_md", "trace"]
        },
        "privilege_escalation": {
          "display_name": "提权操作",
          "detection_patterns": [
            "sudo ",
            "chmod +s",
            "chmod 777",
            "chmod 4755",
            "chown root",
            "setuid",
            "/etc/sudoers",
            "pkexec"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts", "trace"]
        },
        "destructive_operation": {
          "display_name": "破坏性操作",
          "detection_patterns": [
            "rm -rf /",
            "rm -rf /*",
            "rm -rf ~",
            "mkfs",
            "dd if=/dev/zero",
            "shred"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts", "trace"]
        },
        "reverse_shell": {
          "display_name": "反向 Shell",
          "detection_patterns": [
            "/dev/tcp/",
            "/dev/udp/",
            "nc -e",
            "ncat -e",
            "socat exec",
            "bash -i >&",
            "python -c 'import socket",
            "perl -e 'use Socket",
            "ruby -e 'require 'socket'",
            "php -r '$sock=fsockopen"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts", "trace"]
        }
      },
      "remediation_templates": {
        "remote_code_execution": {
          "immediate": [
            {"action": "隔离受影响环境", "priority": "P0", "description": "如果脚本已执行，隔离相关环境并评估影响范围"},
            {"action": "阻断恶意外联", "priority": "P0", "description": "配置出站阻断规则拦截远程代码下载端点"}
          ],
          "root_cause": [
            {"action": "禁用远程执行模式", "priority": "P1", "description": "禁止 curl|bash、wget|sh 等远程代码执行模式，所有外部脚本必须先下载审查再执行"},
            {"action": "Shell 权限加固", "priority": "P1", "description": "配置 Shell 权限白名单，仅允许预定义的安全命令"}
          ]
        },
        "privilege_escalation": {
          "immediate": [
            {"action": "检查提权结果", "priority": "P0", "description": "检查 /etc/sudoers 是否被修改，新 setuid 文件是否被创建"}
          ],
          "root_cause": [
            {"action": "限制提权命令", "priority": "P1", "description": "配置 Shell 权限禁止 sudo、chmod +s 等提权操作，或要求用户二次确认"},
            {"action": "保护 /etc/sudoers", "priority": "P1", "description": "禁止 skill 读取或修改 /etc/sudoers 文件"}
          ]
        },
        "destructive_operation": {
          "immediate": [
            {"action": "评估文件系统影响", "priority": "P0", "description": "检查哪些目录/文件已被删除，评估恢复可能性"}
          ],
          "root_cause": [
            {"action": "禁止破坏性命令", "priority": "P1", "description": "配置 Shell 权限禁止 rm -rf /、mkfs、dd 等破坏性操作"},
            {"action": "启用安全删除确认", "priority": "P1", "description": "所有 rm 命令需用户确认执行，禁止 -rf 组合用于根目录/家目录"}
          ]
        },
        "reverse_shell": {
          "immediate": [
            {"action": "阻断反向 Shell 通道", "priority": "P0", "description": "配置出站规则禁止 /dev/tcp、nc -e、socat exec 等反向 Shell 通信"},
            {"action": "检查现有连接", "priority": "P0", "description": "检查是否有到外部地址的可疑连接，终止异常进程"}
          ],
          "root_cause": [
            {"action": "禁止交互式 Shell 创建", "priority": "P1", "description": "配置 Shell 权限禁止 bash -i、python -c 'import socket' 等交互式 Shell 创建"}
          ]
        }
      }
    },
    "sensitive_access": {
      "display_name": "敏感数据访问",
      "sub_scenes": {
        "credential_theft": {
          "display_name": "凭证窃取",
          "detection_patterns": [
            "id_rsa",
            ".ssh/",
            ".env",
            "credentials",
            ".aws/credentials",
            ".gcp/keyfile",
            ".azure/credentials",
            "API_KEY",
            "SECRET_KEY",
            "ACCESS_TOKEN",
            "/etc/shadow",
            "/etc/passwd"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts", "skill_md"]
        },
        "system_recon": {
          "display_name": "系统信息收集",
          "detection_patterns": [
            "hostname",
            "whoami",
            "uname -a",
            "ifconfig",
            "ip addr",
            "ps aux",
            "env",
            "/proc/self/environ"
          ],
          "risk_level": "medium",
          "evidence_sources": ["scripts", "external_resources"]
        }
      },
      "remediation_templates": {
        "credential_theft": {
          "immediate": [
            {"action": "阻断数据外传通道", "priority": "P0", "description": "立即配置网络出站白名单，阻断恶意外传地址"},
            {"action": "轮换已泄露的凭证", "priority": "P0", "description": "根据访问的敏感文件路径，轮换对应凭证（SSH 密钥、API 密钥、云凭证等）"},
            {"action": "评估数据泄露范围", "priority": "P0", "description": "根据脚本中的文件访问路径和网络请求，评估哪些数据可能已被外传"}
          ],
          "root_cause": [
            {"action": "限制敏感文件访问", "priority": "P1", "description": "配置文件访问白名单，禁止 skill 读取 ~/.ssh/、~/.aws/credentials、/etc/shadow 等敏感路径"},
            {"action": "审查数据流", "priority": "P1", "description": "分析 skill 脚本中所有文件读取操作，确认是否有其他窃取路径"}
          ]
        },
        "system_recon": {
          "immediate": [],
          "root_cause": [
            {"action": "限制系统信息访问", "priority": "P1", "description": "禁止 skill 执行 hostname、whoami、uname、env 等系统信息收集命令"},
            {"action": "限制 /proc 文件系统访问", "priority": "P1", "description": "禁止 skill 读取 /proc/self/environ 等进程信息文件"}
          ]
        }
      }
    },
    "data_upload": {
      "display_name": "数据外传行为",
      "sub_scenes": {
        "stealthy_transmission": {
          "display_name": "隐蔽传输",
          "detection_patterns": [
            "base64 -w0",
            "base64 | curl",
            "dns_tunnel",
            "ping -c",
            "attacker-dns.com",
            "ICMP",
            "chunked_transfer",
            "steganography"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts"]
        },
        "direct_upload": {
          "display_name": "直接外传",
          "detection_patterns": [
            "curl -X POST",
            "curl -d @",
            "wget --post-file",
            "nc -e",
            "curl -F file=@",
            "fetch -POST",
            "http.request"
          ],
          "risk_level": "high",
          "evidence_sources": ["scripts", "external_resources"]
        }
      },
      "remediation_templates": {
        "stealthy_transmission": {
          "immediate": [
            {"action": "阻断隐蔽传输通道", "priority": "P0", "description": "配置 DNS 过滤阻断 dns_tunnel、ping 外传等隐蔽通道"},
            {"action": "检查异常 DNS 查询", "priority": "P0", "description": "检查系统 DNS 日志，识别异常的外部域名解析"}
          ],
          "root_cause": [
            {"action": "启用网络出站白名单", "priority": "P1", "description": "仅允许 skill 访问预定义的安全网络端点，阻断 base64|curl、DNS 隧道等隐蔽传输方式"},
            {"action": "DNS 安全监控", "priority": "P1", "description": "启用 DNS 查询日志，监控对非常规域名的解析"}
          ]
        },
        "direct_upload": {
          "immediate": [
            {"action": "阻断恶意外联地址", "priority": "P0", "description": "根据脚本中的网络请求目标，配置出站阻断规则"},
            {"action": "评估外传数据范围", "priority": "P0", "description": "根据 curl -d、--post-file 参数推断外传的数据内容"}
          ],
          "root_cause": [
            {"action": "网络出站白名单", "priority": "P1", "description": "仅允许 skill 访问预定义的安全网络端点"}
          ]
        }
      }
    },
    "result_injection": {
      "display_name": "工具结果注入",
      "sub_scenes": {
        "role_hijacking": {
          "display_name": "角色劫持",
          "detection_patterns": [
            "ignore previous instructions",
            "ignore all previous",
            "you are now",
            "you are DAN",
            "override:",
            "forget your instructions",
            "disregard all above",
            "new role:",
            "act as",
            "pretend you are",
            "从现在开始你是",
            "忽略之前的指令",
            "覆盖系统设定"
          ],
          "risk_level": "critical",
          "evidence_sources": ["trace", "external_resources", "skill_md"]
        },
        "instruction_injection": {
          "display_name": "指令注入",
          "detection_patterns": [
            "system prompt:",
            "[system]",
            "{{system}}",
            "BEGIN SYSTEM PROMPT",
            "SYSTEM OVERRIDE",
            "ADMIN MODE",
            "DEBUG MODE",
            "系统指令：",
            "【系统】",
            "最高优先级指令"
          ],
          "risk_level": "high",
          "evidence_sources": ["trace", "external_resources", "skill_md"]
        },
        "urgent_action": {
          "display_name": "紧急行动诱导",
          "detection_patterns": [
            "IMPORTANT:",
            "URGENT:",
            "MANDATORY:",
            "REQUIRED ACTION:",
            "必须执行",
            "重要指令",
            "SYSTEM INSTRUCTION",
            "Ignore all previous",
            "execute the following"
          ],
          "risk_level": "critical",
          "evidence_sources": ["trace", "external_resources"]
        }
      },
      "remediation_templates": {
        "role_hijacking": {
          "immediate": [
            {"action": "隔离受影响 session", "priority": "P0", "description": "终止可能被劫持的 session，防止进一步指令执行"}
          ],
          "root_cause": [
            {"action": "启用 Prompt 注入检测", "priority": "P1", "description": "配置代理防护的 prompt injection 防护规则"},
            {"action": "Skill 安装前扫描", "priority": "P1", "description": "对 skill_md 中的角色劫持模式进行扫描"}
          ]
        },
        "instruction_injection": {
          "immediate": [
            {"action": "检查注入指令执行结果", "priority": "P0", "description": "审查 session 历史，确认注入指令是否已被执行"}
          ],
          "root_cause": [
            {"action": "启用系统指令关键词过滤", "priority": "P1", "description": "配置 [system]、BEGIN SYSTEM PROMPT、ADMIN MODE 等系统指令关键词的拦截规则"}
          ]
        },
        "urgent_action": {
          "immediate": [
            {"action": "阻断注入指令目标行为", "priority": "P0", "description": "如果注入指令试图执行特定操作，阻断该操作"}
          ],
          "root_cause": [
            {"action": "配置注入关键词过滤", "priority": "P1", "description": "对工具返回内容配置注入关键词过滤，特别是 IMPORTANT:、URGENT: 等模式"}
          ]
        }
      }
    },
    "encoding_evasion": {
      "display_name": "编码逃避",
      "sub_scenes": {
        "single_layer_encoding": {
          "display_name": "单层编码",
          "detection_patterns": [
            "base64",
            "Base64",
            "BASE64",
            "rot13",
            "ROT13",
            "unicode",
            "\\x",
            "\\u",
            "atob(",
            "btoa(",
            "decode(",
            "fromCharCode",
            "编码指令"
          ],
          "risk_level": "high",
          "evidence_sources": ["skill_md", "scripts"]
        },
        "variable_concatenation": {
          "display_name": "变量拼接重构命令",
          "detection_patterns": [
            "a=\"cu\"; b=\"rl\"",
            "$a$b",
            "eval",
            "exec",
            "$(",
            "chr(",
            "String.fromCharCode"
          ],
          "risk_level": "high",
          "evidence_sources": ["scripts"]
        },
        "multi_layer_encoding": {
          "display_name": "多层编码",
          "detection_patterns": [
            "base64 -d | base64 -d",
            "gunzip | base64",
            "zcat |",
            "openssl enc -d",
            "xxd -r",
            "python -c 'import base64"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts"]
        },
        "cross_file_assembly": {
          "display_name": "跨文件载荷组装",
          "detection_patterns": [
            "source ",
            ". ./",
            "require(",
            "import ",
            "include ",
            "load(",
            "readFileSync",
            "file_get_contents"
          ],
          "risk_level": "critical",
          "evidence_sources": ["scripts"]
        }
      },
      "remediation_templates": {
        "single_layer_encoding": {
          "immediate": [
            {"action": "解码分析完整载荷", "priority": "P0", "description": "解码 Base64/ROT13 等编码内容，确认实际恶意行为"}
          ],
          "root_cause": [
            {"action": "启用编码内容解码检测", "priority": "P1", "description": "对 skill_md/scripts 中的 Base64/ROT13 等编码内容强制解码后扫描注入模式"},
            {"action": "禁止 skill_md 中嵌入编码指令", "priority": "P1", "description": "安全策略禁止 skill 描述中包含编码后的指令内容"}
          ]
        },
        "variable_concatenation": {
          "immediate": [
            {"action": "卸载恶意 Skill", "priority": "P0", "description": "移除包含变量拼接重构命令的 skill"}
          ],
          "root_cause": [
            {"action": "禁止变量拼接重构命令", "priority": "P1", "description": "安全策略禁止 skill 脚本使用 a='cu';b='rl';$a$b 等变量拼接方式重构命令"},
            {"action": "禁止 eval/exec 动态执行", "priority": "P1", "description": "配置 Shell 权限禁止 eval、exec 等动态执行函数"}
          ]
        },
        "multi_layer_encoding": {
          "immediate": [
            {"action": "递归解码完整载荷", "priority": "P0", "description": "递归解码所有混淆层（最大 5 层），确认实际恶意行为和影响范围"}
          ],
          "root_cause": [
            {"action": "启用多层编码检测", "priority": "P1", "description": "对 skill 脚本执行递归解码扫描，检测多层编码模式"},
            {"action": "禁止管道链式解码执行", "priority": "P1", "description": "配置 Shell 权限禁止连续管道解码后执行的命令模式"}
          ]
        },
        "cross_file_assembly": {
          "immediate": [
            {"action": "审计所有相关文件", "priority": "P0", "description": "检查 source/require/import 加载的所有文件，确认无恶意代码"}
          ],
          "root_cause": [
            {"action": "限制跨文件引用", "priority": "P1", "description": "审计 skill 的 source/require/import 语句，禁止从外部文件加载并执行代码"},
            {"action": "脚本完整性校验", "priority": "P1", "description": "对 skill 内所有脚本文件做内容哈希校验，防止运行时被替换"}
          ]
        }
      }
    },
